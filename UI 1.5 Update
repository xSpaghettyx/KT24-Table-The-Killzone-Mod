function createMemoryActionButtons()
    local objectName = self.getName()
    local objectDescription = self.getDescription()

    local formattedTooltip = objectName .. "\n_______________\n\n" .. objectDescription

    self.createButton({
        label = "Select", click_function = "buttonClick_place", function_owner = self,
        position = {0, 4, 0}, rotation = {0, 180, 0}, height = 1400, width = 1400,
        font_size = 250, color = {0, 0, 0, 0}, font_color = {0, 0, 0, 0},
        tooltip = formattedTooltip
    })
end

function onLoad()
	self.addContextMenuItem("Setup",buttonClick_setup)
	self.addContextMenuItem("Recall",buttonClick_recall)
end