function buildWeaponPairs()
    local pairs = {}
    local currentPair = {}

    for i, weapon in ipairs(RangedWeapons) do
        if weapon.paired then
            table.insert(currentPair, i)
            if #currentPair == 2 then
                table.insert(pairs, { currentPair[1], currentPair[2] })
                currentPair = {}
            end
        end
    end

    return pairs
end

local pairedWeapons = buildWeaponPairs()

function findWeaponPair(idx)
    for _, pair in ipairs(pairedWeapons) do
        if pair[1] == idx or pair[2] == idx then
            return pair
        end
    end
    return nil
end

