function rebuildDescription(model, data)
    local lines = {}
    table.insert(lines, string.format(
        "[D36B3E][[84E680]APL[-] [ffffff]%s[-]] [[84E680]MOVE[-] [ffffff]%s\"[-]]",
        tostring(data.stats.APL), tostring(data.stats.Move)))
    table.insert(lines, string.format(
        "[[84E680]SAVE[-] [ffffff]%s+[-]] [[84E680]WOUNDS[-] [ffffff]%s[-]][-]",
        tostring(data.stats.Save), tostring(data.stats.Wounds)))

    if data.keywords then
        table.insert(lines, "[C5C5C5]" .. table.concat(data.keywords, ", ") .. "[-]")
    end

    table.insert(lines, "[31B32B]Weapons[-]")
    if data.weapons then
        for _, w in ipairs(data.weapons) do
            table.insert(lines, w.name or "?")
            local s = w.stats or {}
            table.insert(lines, string.format("[84E680]ATK[-] %s [84E680]HIT[-] %s [84E680]DMG[-] %s",
                s.ATK or "?", s.HIT or "?", s.DMG or "?"))
            if s.WR and s.WR ~= "" then
                table.insert(lines, "[84E680]WR[-]: " .. s.WR)
            end
            table.insert(lines, "")
        end
    end

    if data.abilities and #data.abilities > 0 then
        table.insert(lines, "---")
        table.insert(lines, "[31B32B]Abilities[-]")
        for _, ab in ipairs(data.abilities) do
            table.insert(lines, "- [EF8450]" .. (ab.name or "?") .. "[-]")
        end
    end

    if data.actions and #data.actions > 0 then
        table.insert(lines, "[31B32B]Actions[-]")
        for _, ac in ipairs(data.actions) do
            table.insert(lines, "- [D46D6C]" .. (ac.name or "?") .. "[-]")
        end
    end

    local desc = table.concat(lines, "\n")
    model.setDescription(desc)
    return desc
end

function findModelOnCard()
    local pos = self.getPosition()
    local hits = Physics.cast({
        origin       = Vector(pos.x, pos.y + 1.5, pos.z),
        direction    = {0, -1, 0},
        type         = 2,
        size         = {2, 2, 2},
        max_distance = 3,
    })
    for _, hit in ipairs(hits) do
        local obj = hit.hit_object
        if obj and obj ~= self then
            if obj.type == "Custom_Model" or obj.type == "Figurine" then
                return obj
            end
        end
    end
    return nil
end

function ensureKTUIMini(model)
    if not model.hasTag("KTUIMini") then
        model.addTag("KTUIMini")
    end

    local guid = model.getGUID()
    local url = "https://raw.githubusercontent.com/xSpaghettyx/KT24-Table-The-Killzone-Mod/refs/heads/main/KT%20UI%20extender%2024%20Spaghetty%20Mod.lua"

    WebRequest.get(url, function(req)
        if req.is_error then
            printToAll("Failed to fetch KTUIMini script: " .. req.error, {1,0,0})
            return
        end

        local target = getObjectFromGUID(guid)
        if target == nil then
            printToAll("Target model no longer exists.", {1,0,0})
            return
        end

        target.setLuaScript(req.text)
        printToAll("Stats applied to target model.", {0,1,0})
    end)
end

function applyStatsToModel(player_color)
    local model = findModelOnCard()
    if model == nil then
        broadcastToColor("No model found. Make sure it is set to *Figurine* in Custom settings", player_color, Color.Orange)
        return
    else
        ensureKTUIMini(model)
    end

    local data = {}

    local name = self.UI.getAttribute("operativeName", "text")
    if name == nil or name == "" then
        name = "Nemesis Operative"
    end
    data.name = name

    local woundsText = tonumber(self.UI.getAttribute("woundsText", "text")) or 0
    data.stats = {
        APL    = self.UI.getAttribute("controlText", "text"),
        Move   = self.UI.getAttribute("moveText", "text"),
        Save   = self.UI.getAttribute("saveText", "text"),
        Wounds = woundsText,
    }

    local allegianceHeader = self.UI.getAttribute("allegianceTrait_header", "text") or ""
    local firstWord = allegianceHeader:match("^(%S+)") or ""
    data.keywords = { "Nemesis Operative", firstWord }

    data.weapons = {}
    local rowIndex = 1
    while true do
        local weaponName = self.UI.getAttribute("row"..rowIndex.."_weaponName", "text")
        if not weaponName or weaponName == "" then break end

        local slotImage = self.UI.getAttribute("row"..rowIndex.."_btnCycle", "WeaponSlotImage")
        local prefix = (slotImage == "2") and "[F4641D]M[-] " or "[1E87FF]R[-] "

        table.insert(data.weapons, {
            name       = prefix .. weaponName,
            plain_name = weaponName,
            stats = {
                ATK = self.UI.getAttribute("row"..rowIndex.."_atk", "text"),
                HIT = self.UI.getAttribute("row"..rowIndex.."_hit", "text"),
                DMG = self.UI.getAttribute("row"..rowIndex.."_dmg", "text"),
                WR  = self.UI.getAttribute("row"..rowIndex.."_wr", "text"),
            }
        })

        rowIndex = rowIndex + 1
    end

    data.abilities = {}

    table.insert(data.abilities, {
        name = self.UI.getAttribute("allegianceTrait_header", "text"),
        text = self.UI.getAttribute("allegianceTrait_body", "text"),
    })

    for i = 1, 3 do
        local header = self.UI.getAttribute("nemesisTrait"..i.."_header", "text")
        local body   = self.UI.getAttribute("nemesisTrait"..i.."_body", "text")
        if header and header ~= "" then
            table.insert(data.abilities, { name = header, text = body })
        end
    end

    local coreRules = {}
    local idx = 1
    while true do
        local btnId = "CoreRuleBtn"..idx
        local color = self.UI.getAttribute(btnId, "color")
        if not color then break end
        if color:lower() == "#ff7b00" then
            local txt = self.UI.getAttribute(btnId, "text")
            if txt and txt ~= "" then table.insert(coreRules, txt) end
        end
        idx = idx + 1
    end

    local npoText = ""
    for i = 1, 4 do
        local btnId = "NpoBtn"..i
        local state = self.UI.getAttribute(btnId, "npoBehaviourStates")
        if state == "true" then
            npoText = self.UI.getAttribute(btnId, "text") or ""
            break
        end
    end

    table.insert(data.abilities, {
        name = "Nemesis Core Rules",
        text = table.concat(coreRules, ", ") .. "\n\nNPO Behaviour: " .. npoText
    })

    local changes = diffAndApply(model, data)

    local msRaw = model.script_state
    local ms = {}
    if msRaw and msRaw ~= "" then
        local ok, parsed = pcall(function() return JSON.decode(msRaw) end)
        if ok and parsed then ms = parsed end
    end

    ms.stats = ms.stats or {}
    ms.stats.Wounds = woundsText
    ms.wounds = woundsText

    model.script_state = JSON.encode(ms)
end

