function onRWeaponButtonClicked(player, value, id)
    self.UI.setAttributes("RweaponGrid", {active="false"})

    local idx = tonumber(id:match("%d+"))
    local weapon = RangedWeapons[idx]
    if not weapon then return end

    local targetRow = LastCycleRow or 1
    local pair = findWeaponPair(idx)

    if pair then
        local w1 = RangedWeapons[pair[1]]
        local w2 = RangedWeapons[pair[2]]

        if w1 then
            self.UI.setAttributes("row"..targetRow.."_weaponName", { text = w1.name })
            self.UI.setAttributes("row"..targetRow.."_atk",        { text = w1.atk })
            self.UI.setAttributes("row"..targetRow.."_hit",        { text = w1.hit })
            self.UI.setAttributes("row"..targetRow.."_dmg",        { text = w1.dmg })
            self.UI.setAttributes("row"..targetRow.."_wr",         { text = w1.wr })
        end

        if w2 then
            local nextRow = targetRow + 1
            self.UI.setAttributes("row"..nextRow.."_weaponName", { text = w2.name })
            self.UI.setAttributes("row"..nextRow.."_atk",        { text = w2.atk })
            self.UI.setAttributes("row"..nextRow.."_hit",        { text = w2.hit })
            self.UI.setAttributes("row"..nextRow.."_dmg",        { text = w2.dmg })
            self.UI.setAttributes("row"..nextRow.."_wr",         { text = w2.wr })
        end
    else
        self.UI.setAttributes("row"..targetRow.."_weaponName", { text = weapon.name })
        self.UI.setAttributes("row"..targetRow.."_atk",        { text = weapon.atk })
        self.UI.setAttributes("row"..targetRow.."_hit",        { text = weapon.hit })
        self.UI.setAttributes("row"..targetRow.."_dmg",        { text = weapon.dmg })
        self.UI.setAttributes("row"..targetRow.."_wr",         { text = weapon.wr })
    end
