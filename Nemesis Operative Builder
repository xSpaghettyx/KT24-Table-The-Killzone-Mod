function computeUiHeight(base, mode, value)
    if mode == "fixed" and value then
        return value
    end
    if base.x == base.z then
        return base.x / 48
    else
        return math.min(base.x, base.z) / 48
    end
end

function highlightButton(activeId)
    local ids = {"btnAuto","btn2","btn3","btn4","btn6"}
    for _, id in ipairs(ids) do
        local color = (id == activeId) and "#00AA00" or "#444444"
        self.UI.setAttribute(id, "color", color)
        self.UI.setAttribute(id, "textColor", "#FFFFFF")
    end
end

function getCurrentUiHeightMode()
    local ids = {"btnAuto","btn2","btn3","btn4","btn6"}
    for _, id in ipairs(ids) do
        local color = self.UI.getAttribute(id, "color")
        if color == "#00AA00" then
            if id == "btnAuto" then return "auto", nil
            elseif id == "btn2" then return "fixed", 2
            elseif id == "btn3" then return "fixed", 3
            elseif id == "btn4" then return "fixed", 4
            elseif id == "btn6" then return "fixed", 6
            end
        end
    end
    return "auto", nil
end

